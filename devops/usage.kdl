name "cambridge-reader-scraper"
bin "cambridge-reader-scraper"
about "cambridge-reader-scraper rebuilds Cambridge Reader books into PDFs."

flag "--userdata <value>" help="path to the Cambridge Reader userdata root"
flag "--app-name <value>" help="override the app name used for default userdata discovery"
flag "--isbn <value>" help="limit work to one or more ISBN values"
flag "--outdir <value>" help="output directory for generated PDFs"
flag "--workdir <value>" help="temporary extraction directory"
flag "--browser <value>" help="path to a Playwright Chromium executable"
flag "--cdp-url <value>" help="CDP endpoint for CloakBrowser browser mode"
flag "--browser-scrape" help="scrape through Cambridge GO in a browser instead of local userdata"
flag "--url <value>" help="Cambridge GO reader URL for browser scraping"
flag "--email <value>" help="Cambridge GO email for browser scraping"
flag "--password <value>" help="Cambridge GO password for browser scraping"
flag "--page-timeout-ms <value>" help="page navigation timeout in milliseconds"
flag "--max-pages <value>" help="render only the first N pages of each book"
flag "--concurrency <value>" help="number of books to process in parallel"
flag "--keep-extracted" help="keep extracted book files after rendering"
flag "--no-tui" help="disable the interactive selection and progress UI"
flag "--help" help="show CLI help"

cmd "reconstruct" help="rebuild selected books into PDFs"
cmd "pdf" help="alias for reconstruct"
cmd "inspect" help="list detected Cambridge Reader book blobs"
cmd "completion" help="print a shell completion script" {
  arg "shell" help="completion shell: bash, zsh, fish, or powershell"
}
cmd "help" help="show CLI help"
